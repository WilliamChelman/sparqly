era-sh:TNvovtrp
	a sh:PropertyShape ;
    era:affectedProperty era:tNvovtrp;
    era:affectedClass era:ETCS;
    era:scope "local";
	rdfs:comment "Maximum time for overriding the train trip in seconds. "@en ;
