    sh:select """
        PREFIX era: <http://data.europa.eu/949/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        SELECT DISTINCT $this {
            $this era:notApplicable ?o .
            FILTER NOT EXISTS {
                $this a ?type .
                ?type rdfs:subClassOf* era:InfrastructureElement .
            }
        }""" .

