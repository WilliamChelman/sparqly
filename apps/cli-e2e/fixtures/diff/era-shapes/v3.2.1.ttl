    era:affectedProperty era:hasFlangeLubrication ;
    era:affectedClass era:VehicleType ;
    era:scope "local" ;
    rdfs:comment "Validation for hasFlangeLubrication property." ;
    sh:path era:hasFlangeLubrication ;
    sh:datatype xsd:boolean ;
