    sh:prefixes era: ;
    sh:select """
        PREFIX era: <http://data.europa.eu/949/>
        PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        SELECT $this (era:otherCCSSystemOnboard AS ?path) (?concept AS ?value) ?label
