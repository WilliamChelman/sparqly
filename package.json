  "scripts": {
    "dev": "nx run-many -t serve -p cli web --parallel=2",
    "dev:cli": "nx serve cli",
    "dev:web": "nx serve web",
    "build": "nx run-many -t build --no-tui",
    "build:cli": "nx build cli --no-tui",
    "build:web": "nx build web --no-tui",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "tdd": "nx run-many -t lint test --no-tui",
    "e2e": "nx run-many -t build e2e",
    "check": "nx run-many -t build lint test e2e",
    "sparqly": "nx build cli --no-tui && node dist/apps/cli/main.js"
  },
