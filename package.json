{
  "name": "sparqly-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "24.15.0"
